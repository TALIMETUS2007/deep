// Firestore Security Rules for Deep
// Copy this into Firebase Console → Firestore Database → Rules,
// then click "Publish."
//
// What this does:
// - Anyone (including signed-out visitors) can READ testimonials,
//   community photos, and seed comments — the site is public.
// - Only a signed-in user can CREATE a new testimonial or photo,
//   and only as themselves (ownerUid must match their own UID).
// - Only the original owner can DELETE or UPDATE their own post.
// - Comments (arrayUnion) require being signed in.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /testimonials/{id} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
    }

    match /communityPhotos/{id} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
      // Updates are used for adding comments — allow any signed-in
      // user (not just the owner) so people can comment on others' photos.
      allow update: if request.auth != null;
    }

    match /seedComments/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
